# =============================================================================
# Ritual Research Desk — environment (copy to .env.local for Vercel/local)
# =============================================================================

# --- Surf 2.0 / Chat API (server-only — never expose to browser) ---
# Get key at https://agents.asksurf.ai  (Skill / API billing)
SURF_API_KEY=sk-your_surf_api_key_here
# Default gateway from Surf CLI docs
# Chat completions was removed (410). App uses POST {BASE}/responses
SURF_API_BASE_URL=https://api.asksurf.ai/gateway/v1
# Models: surf-1.5 | surf-1.5-instant | surf-1.5-thinking
# Prefer instant on Vercel (faster → fewer 504 timeouts)
SURF_MODEL=surf-1.5-instant

# --- Auto agent wakes (server keeper) ---
# Fund this wallet with a little RIT for gas only (tick fee comes from agent balance)
# KEEPER_PRIVATE_KEY=0x...
# Protect /api/agent/cron — Authorization: Bearer <CRON_SECRET> only
# CRON_SECRET=long-random-string
# Encrypts research reports until settle (defaults to CRON_SECRET / SURF key if unset)
# REPORT_SEAL_SECRET=another-long-random-string

# --- Telegram agent tick DMs (optional) ---
# Create bot with @BotFather → TELEGRAM_BOT_TOKEN
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBotUsername  (no @)
# TELEGRAM_WEBHOOK_SECRET=long-random  (Telegram setWebhook secret_token; required on Vercel)
# Full guide: TELEGRAM.md
# TELEGRAM_BOT_TOKEN=
# NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=
# TELEGRAM_WEBHOOK_SECRET=
#
# Multi-user unattended DMs (recommended on Vercel — free Upstash Redis REST):
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Users only click Connect Telegram in the app (no per-user env).
#
# Approx Ritual block time for minutes/hours → blocks conversion
# NEXT_PUBLIC_RITUAL_BLOCK_TIME_SEC=2
#
# Hobby Vercel only allows ONE native cron per day (vercel.json uses 0 0 * * *).
# For frequent wakes: Pro plan or external cron with header:
#   Authorization: Bearer <CRON_SECRET>
# Disable Deployment Protection or use Protection Bypass so cron can reach the API.

# --- Ritual chain (public ok) ---
NEXT_PUBLIC_CHAIN_ID=1979
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org
NEXT_PUBLIC_EXPLORER_URL=https://explorer.ritualfoundation.org

# Research fee in native RITUAL (human-readable for UI)
NEXT_PUBLIC_RESEARCH_FEE=0.005

# Deployed ResearchDesk contract (set after forge deploy)
NEXT_PUBLIC_RESEARCH_CONTRACT=0xd3469a23b2a08b237bc6c0522845eb1b508e5352
NEXT_PUBLIC_BOUNTY_CONTRACT=0xbc4bc83298950cbda52837cd806d41ad7c3c36bf

# Treasury (50% of fees) — public address only
NEXT_PUBLIC_FEE_RECIPIENT=0xd3309Bf2E2D1F451132dbC34Dc5908C442903458

# Radar agent registry (on-chain)
NEXT_PUBLIC_RADAR_CONTRACT=0x50a3fb54aa1289546a0be2d6b29d689bb2dd5f6f

# --- Deploy-only (local Foundry; NOT needed on Vercel) ---
# FEE_RECIPIENT_ADDRESS=0xd3309Bf2E2D1F451132dbC34Dc5908C442903458
# PRIVATE_KEY=
# RITUAL_RPC_URL=https://rpc.ritualfoundation.org
# RESEARCH_FEE_WEI=5000000000000000
# BOUNTY_INTERACTION_THRESHOLD=20
